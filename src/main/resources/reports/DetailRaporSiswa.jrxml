			<!-- R4: B. Indo -->
			<staticText><reportElement x="0" y="286" width="200" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement verticalAlignment="Middle"><paragraph leftIndent="8"/></textElement><text><![CDATA[Bahasa Indonesia]]></text></staticText>
