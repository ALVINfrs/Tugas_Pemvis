				<staticText><reportElement x="10" y="5" width="515" height="14" forecolor="#1A237E"/><textElement><font size="9" isBold="true"/></textElement><text><![CDATA[RINGKASAN PROFIL AKADEMIK:]]></text></staticText>
				<textField isStretchWithOverflow="true"><reportElement x="10" y="22" width="515" height="50" forecolor="#616161"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA["Siswa " + ($F{nama}!=null?$F{nama}:"-") + " dari kelas " + ($F{kelas}!=null?$F{kelas}:"-") + " jurusan " + ($F{jurusan_sma}!=null?$F{jurusan_sma}:"-") + " memiliki rata-rata akademik " + (($F{nilai_matematika} != null && $F{nilai_ipa} != null) ? new java.text.DecimalFormat("0.00").format(($F{nilai_matematika}.doubleValue() + $F{nilai_ipa}.doubleValue() + $F{nilai_ips}.doubleValue() + $F{nilai_bahasa_ind}.doubleValue() + $F{nilai_bahasa_ing}.doubleValue() + $F{nilai_seni}.doubleValue()) / 6.0) : "-") + ". Berdasarkan hasil asesmen sistem pakar, siswa direkomendasikan untuk menempuh pendidikan tinggi di jurusan " + ($F{rekomendasi_utama}!=null?$F{rekomendasi_utama}:"-") + " (Rumpun: " + ($F{rumpun_utama}!=null?$F{rumpun_utama}:"-") + ")."]]></textFieldExpression></textField>
			</frame>
