			<textField><reportElement x="300" y="254" width="235" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_ipa} != null ? ($F{nilai_ipa}.doubleValue() >= 85 ? "SANGAT MEMADAI" : ($F{nilai_ipa}.doubleValue() >= 75 ? "MEMADAI" : "PERLU PENINGKATAN")) : "-"]]></textFieldExpression></textField>

