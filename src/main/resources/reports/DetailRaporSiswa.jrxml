			<textField><reportElement x="330" y="5" width="205" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["Contoh Kota, " + new java.text.SimpleDateFormat("dd MMMM yyyy", new java.util.Locale("id", "ID")).format(new java.util.Date())]]></textFieldExpression></textField>

			<!-- Siswa -->
			<staticText><reportElement x="180" y="22" width="150" height="16"/><textElement textAlignment="Center"><font isBold="true" size="9"/></textElement><text><![CDATA[Siswa Bersangkutan]]></text></staticText>
			<textField><reportElement x="180" y="75" width="150" height="14"/><textElement textAlignment="Center"><font isBold="true" isUnderline="true" size="9"/></textElement><textFieldExpression><![CDATA[$F{nama} != null ? $F{nama} : "__________________"]]></textFieldExpression></textField>
			<textField><reportElement x="180" y="89" width="150" height="14"/><textElement textAlignment="Center"><font size="8"/></textElement><textFieldExpression><![CDATA["NIS. " + ($F{nis} != null ? $F{nis} : "________________")]]></textFieldExpression></textField>

			<!-- Konselor -->
			<staticText><reportElement x="350" y="22" width="185" height="16"/><textElement textAlignment="Center"><font isBold="true" size="9"/></textElement><text><![CDATA[Guru BK / Konselor]]></text></staticText>
			<textField><reportElement x="350" y="75" width="185" height="14"/><textElement textAlignment="Center"><font isBold="true" isUnderline="true" size="9"/></textElement><textFieldExpression><![CDATA[$F{nama_konselor} != null ? $F{nama_konselor} : "__________________"]]></textFieldExpression></textField>
			<textField><reportElement x="350" y="89" width="185" height="14"/><textElement textAlignment="Center"><font size="8"/></textElement><textFieldExpression><![CDATA["NIP. " + ($F{nip_konselor} != null ? $F{nip_konselor} : "________________")]]></textFieldExpression></textField>

			<!-- Footer text -->
			<staticText><reportElement x="0" y="105" width="300" height="12" forecolor="#9E9E9E"/><textElement><font size="7" isItalic="true"/></textElement><text><![CDATA[Digenerate oleh Sistem Pakar Rekomendasi Jurusan v1.0]]></text></staticText>

			<!-- Bottom decorative bars -->
