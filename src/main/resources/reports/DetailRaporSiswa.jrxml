<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DetailRaporSiswa" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>

	<!-- ═══════════════════ SUB-DATASET PTN ═══════════════════ -->
	<subDataset name="DatasetPTN">
		<parameter name="pKonsultasiId" class="java.lang.Integer"/>
		<parameter name="pRank" class="java.lang.Integer"/>
		<queryString language="SQL">
			<![CDATA[
			SELECT u.nama as universitas, u.provinsi, u.akreditasi, uj.passing_grade_snbp, uj.passing_grade_snbt, uj.biaya_kuliah, ru.peluang_personal 
			FROM rekomendasi_univ ru 
			JOIN universitas_jurusan uj ON ru.universitas_jurusan_id = uj.id 
			JOIN universitas u ON uj.universitas_id = u.id 
			WHERE ru.konsultasi_id = $P{pKonsultasiId} AND ru.rank_urutan = $P{pRank}
			]]>
		</queryString>
		<field name="universitas" class="java.lang.String"/>
		<field name="provinsi" class="java.lang.String"/>
		<field name="akreditasi" class="java.lang.String"/>
		<field name="passing_grade_snbp" class="java.math.BigDecimal"/>
		<field name="passing_grade_snbt" class="java.math.BigDecimal"/>
		<field name="biaya_kuliah" class="java.lang.Long"/>
		<field name="peluang_personal" class="java.math.BigDecimal"/>
	</subDataset>

	<!-- ═══════════════════ PARAMETER ═══════════════════ -->
	<parameter name="paramKonsultasiId" class="java.lang.Integer"/>

	<!-- ═══════════════════ MAIN QUERY ═══════════════════ -->
	<queryString language="SQL">
		<![CDATA[
        SELECT s.nis, s.nama, s.kelas, s.tahun_ajaran, s.semester, s.jurusan_sma, s.jenis_kelamin, s.cita_cita, s.hobi, s.prestasi,
        s.nilai_matematika, s.nilai_ipa, s.nilai_ips, s.nilai_bahasa_ind, s.nilai_bahasa_ing, s.nilai_seni,
        DATE_FORMAT(k.tanggal_konsultasi, '%d %M %Y') as tgl_test,
        k.skor_teknologi, k.skor_sains, k.skor_sosial, k.skor_seni, k.skor_bisnis, k.skor_bahasa, k.skor_kesehatan, 
        j.nama as rekomendasi_utama, j.rumpun as rumpun_utama, j.deskripsi as deskripsi_utama, j.prospek_kerja as prospek_utama,
        j2.nama as rekomendasi_alt1, j2.rumpun as rumpun_alt1, j2.deskripsi as deskripsi_alt1, j2.prospek_kerja as prospek_alt1,
        j3.nama as rekomendasi_alt2, j3.rumpun as rumpun_alt2, j3.deskripsi as deskripsi_alt2, j3.prospek_kerja as prospek_alt2,
        k.catatan_konselor, k.tips_belajar, k.rekomendasi_kegiatan, k.status as status_konsultasi,
        c.nama as nama_konselor, c.nip as nip_konselor
        FROM konsultasi k
        LEFT JOIN siswa s ON k.siswa_id = s.id
        LEFT JOIN konselor c ON k.konselor_id = c.id
        LEFT JOIN jurusan_kuliah j ON k.rekomendasi_utama_id = j.id
        LEFT JOIN jurusan_kuliah j2 ON k.rekomendasi_alt1_id = j2.id
        LEFT JOIN jurusan_kuliah j3 ON k.rekomendasi_alt2_id = j3.id
        WHERE k.id = $P{paramKonsultasiId}
        ]]>
	</queryString>

	<!-- ═══════════════════ FIELD DECLARATIONS ═══════════════════ -->
	<field name="nis" class="java.lang.String"/>
	<field name="nama" class="java.lang.String"/>
	<field name="kelas" class="java.lang.String"/>
	<field name="jurusan_sma" class="java.lang.String"/>
	<field name="jenis_kelamin" class="java.lang.String"/>
	<field name="cita_cita" class="java.lang.String"/>
	<field name="hobi" class="java.lang.String"/>
	<field name="prestasi" class="java.lang.String"/>
	<field name="nilai_matematika" class="java.math.BigDecimal"/>
	<field name="nilai_ipa" class="java.math.BigDecimal"/>
	<field name="nilai_ips" class="java.math.BigDecimal"/>
	<field name="nilai_bahasa_ind" class="java.math.BigDecimal"/>
	<field name="nilai_bahasa_ing" class="java.math.BigDecimal"/>
	<field name="nilai_seni" class="java.math.BigDecimal"/>
