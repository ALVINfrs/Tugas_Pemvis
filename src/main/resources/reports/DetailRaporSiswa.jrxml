			<staticText><reportElement x="200" y="220" width="100" height="18" forecolor="#FFFFFF" backcolor="#283593" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#1A237E"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><text><![CDATA[Nilai Rata-rata]]></text></staticText>
			<staticText><reportElement x="300" y="220" width="235" height="18" forecolor="#FFFFFF" backcolor="#283593" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#1A237E"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><text><![CDATA[Kategori Kompetensi]]></text></staticText>

			<!-- R1: Matematika -->
			<staticText><reportElement x="0" y="238" width="200" height="16" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement verticalAlignment="Middle"><paragraph leftIndent="8"/></textElement><text><![CDATA[Matematika]]></text></staticText>
			<textField><reportElement x="200" y="238" width="100" height="16" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_matematika}]]></textFieldExpression></textField>
			<textField><reportElement x="300" y="238" width="235" height="16" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_matematika} != null ? ($F{nilai_matematika}.doubleValue() >= 85 ? "SANGAT MEMADAI" : ($F{nilai_matematika}.doubleValue() >= 75 ? "MEMADAI" : "PERLU PENINGKATAN")) : "-"]]></textFieldExpression></textField>

			<!-- R2: IPA -->
			<staticText><reportElement x="0" y="254" width="200" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement verticalAlignment="Middle"><paragraph leftIndent="8"/></textElement><text><![CDATA[Ilmu Pengetahuan Alam (IPA)]]></text></staticText>
