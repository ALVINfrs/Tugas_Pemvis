				<staticText><reportElement x="10" y="5" width="515" height="12" forecolor="#EF6C00"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[INSIGHT ASESMEN:]]></text></staticText>
				<textField isStretchWithOverflow="true"><reportElement x="10" y="20" width="515" height="18" forecolor="#616161"/><textElement><font size="8"/></textElement><textFieldExpression><![CDATA["Berdasarkan distribusi skor 7 kategori minat, siswa menunjukkan kecenderungan dominan yang dapat menjadi dasar pemilihan jurusan perguruan tinggi yang tepat. Skor tertinggi menjadi indikator utama dalam rekomendasi sistem pakar."]]></textFieldExpression></textField>
