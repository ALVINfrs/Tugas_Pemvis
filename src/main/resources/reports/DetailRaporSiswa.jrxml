	<field name="skor_kesehatan" class="java.lang.Integer"/>
	<field name="rekomendasi_utama" class="java.lang.String"/>
	<field name="rumpun_utama" class="java.lang.String"/>
	<field name="deskripsi_utama" class="java.lang.String"/>
	<field name="prospek_utama" class="java.lang.String"/>
	<field name="rekomendasi_alt1" class="java.lang.String"/>
	<field name="rumpun_alt1" class="java.lang.String"/>
	<field name="deskripsi_alt1" class="java.lang.String"/>
	<field name="prospek_alt1" class="java.lang.String"/>
	<field name="rekomendasi_alt2" class="java.lang.String"/>
	<field name="rumpun_alt2" class="java.lang.String"/>
	<field name="deskripsi_alt2" class="java.lang.String"/>
	<field name="prospek_alt2" class="java.lang.String"/>
	<field name="catatan_konselor" class="java.lang.String"/>
	<field name="tips_belajar" class="java.lang.String"/>
	<field name="rekomendasi_kegiatan" class="java.lang.String"/>
	<field name="nama_konselor" class="java.lang.String"/>
	<field name="nip_konselor" class="java.lang.String"/>

	<!-- ═══════════════════════════════════════════════════════════ -->
	<!-- ██  TITLE BAND – KOP SURAT & JUDUL LAPORAN               ██ -->
	<!-- ═══════════════════════════════════════════════════════════ -->
	<title>
		<band height="135" splitType="Stretch">
			<!-- Top decorative bar -->
			<rectangle><reportElement x="0" y="0" width="535" height="6" backcolor="#1A237E" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
			<!-- Gold accent stripe -->
			<rectangle><reportElement x="0" y="6" width="535" height="2" backcolor="#FFB300" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>

			<!-- School Name -->
			<staticText><reportElement x="0" y="14" width="535" height="22" forecolor="#1A237E"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="16" isBold="true"/></textElement><text><![CDATA[SMAN 1 CONTOH KOTA]]></text></staticText>
			<!-- Address -->
			<staticText><reportElement x="0" y="36" width="535" height="12" forecolor="#616161"/><textElement textAlignment="Center"><font size="8"/></textElement><text><![CDATA[Jalan Pendidikan No. 1, Kota Contoh, Provinsi Jaya 12345 | Telp: (021) 1234567]]></text></staticText>
			<!-- Separator line -->
			<line><reportElement x="0" y="52" width="535" height="1" forecolor="#1A237E"/><graphicElement><pen lineWidth="1.5" lineStyle="Solid"/></graphicElement></line>
			<!-- Thin gold line -->
			<line><reportElement x="0" y="54" width="535" height="1" forecolor="#FFB300"/><graphicElement><pen lineWidth="0.5"/></graphicElement></line>

			<!-- Report Title -->
			<staticText><reportElement x="0" y="62" width="535" height="22" forecolor="#1A237E"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="14" isBold="true"/></textElement><text><![CDATA[LAPORAN HASIL KONSULTASI KARIR & REKOMENDASI JURUSAN]]></text></staticText>
			<!-- Subtitle -->
			<staticText><reportElement x="0" y="84" width="535" height="14" forecolor="#9E9E9E"/><textElement textAlignment="Center"><font size="9" isItalic="true"/></textElement><text><![CDATA[Sistem Pakar Rekomendasi Jurusan Perguruan Tinggi — Laporan Individu Komprehensif]]></text></staticText>

			<!-- Bottom accent bars (navy + gold gradient effect) -->
			<rectangle><reportElement x="0" y="105" width="400" height="4" backcolor="#1A237E" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
			<rectangle><reportElement x="400" y="105" width="135" height="4" backcolor="#FFB300" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>

			<!-- Document number & date -->
			<textField><reportElement x="0" y="115" width="535" height="14" forecolor="#616161"/><textElement textAlignment="Center"><font size="8" isItalic="true"/></textElement><textFieldExpression><![CDATA["Tanggal Cetak: " + new java.text.SimpleDateFormat("dd MMMM yyyy, HH:mm", new java.util.Locale("id", "ID")).format(new java.util.Date()) + " WIB"]]></textFieldExpression></textField>
		</band>
	</title>

	<!-- ═══════════════════════════════════════════════════════════ -->
	<!-- ██  DETAIL BANDS                                          ██ -->
	<!-- ═══════════════════════════════════════════════════════════ -->
	<detail>

	<!-- ─────────── BAND 1: PROFIL SISWA + NILAI RAPOR ─────────── -->
		<band height="480" splitType="Stretch">
			<!-- ▌ SECTION I: PROFIL SISWA ▌ -->
			<rectangle><reportElement x="0" y="0" width="535" height="22" backcolor="#1A237E" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
			<staticText><reportElement x="10" y="0" width="525" height="22" forecolor="#FFFFFF"/><textElement verticalAlignment="Middle"><font size="11" isBold="true"/></textElement><text><![CDATA[I. DATA PROFIL SISWA]]></text></staticText>

			<!-- Profile Card Frame -->
			<frame><reportElement x="0" y="28" width="535" height="155" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#1A237E"/></box>
				<!-- Row 1: Nama -->
				<staticText><reportElement x="10" y="8" width="120" height="15"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Nama Lengkap]]></text></staticText>
				<textField><reportElement x="130" y="8" width="140" height="15"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[": " + ($F{nama}!=null?$F{nama}:"-")]]></textFieldExpression></textField>
				<staticText><reportElement x="280" y="8" width="100" height="15"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[NIS]]></text></staticText>
				<textField><reportElement x="380" y="8" width="145" height="15"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[": " + ($F{nis}!=null?$F{nis}:"-")]]></textFieldExpression></textField>

				<!-- Row 2: Kelas & JK -->
				<rectangle><reportElement x="5" y="26" width="525" height="17" backcolor="#EEF2F7" mode="Opaque"/><graphicElement><pen lineWidth="0.0"/></graphicElement></rectangle>
				<staticText><reportElement x="10" y="27" width="120" height="15"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Kelas / Jurusan SMA]]></text></staticText>
				<textField><reportElement x="130" y="27" width="140" height="15"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[": " + ($F{kelas}!=null?$F{kelas}:"-") + " / " + ($F{jurusan_sma}!=null?$F{jurusan_sma}:"-")]]></textFieldExpression></textField>
				<staticText><reportElement x="280" y="27" width="100" height="15"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Jenis Kelamin]]></text></staticText>
				<textField><reportElement x="380" y="27" width="145" height="15"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[": " + ($F{jenis_kelamin}!=null?($F{jenis_kelamin}.equals("L")?"Laki-laki":"Perempuan"):"-")]]></textFieldExpression></textField>

				<!-- Row 3: Tanggal & Cita-cita -->
				<staticText><reportElement x="10" y="47" width="120" height="15"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Tanggal Konsultasi]]></text></staticText>
				<textField><reportElement x="130" y="47" width="140" height="15"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[": " + ($F{tgl_test}!=null?$F{tgl_test}:"-")]]></textFieldExpression></textField>
				<staticText><reportElement x="280" y="47" width="100" height="15"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Cita-cita]]></text></staticText>
