				<textField isStretchWithOverflow="true"><reportElement x="130" y="66" width="395" height="15"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[": " + ($F{hobi}!=null?$F{hobi}:"-")]]></textFieldExpression></textField>

				<!-- Row 5: Prestasi -->
