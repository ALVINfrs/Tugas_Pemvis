			<textField><reportElement x="300" y="286" width="235" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_bahasa_ind} != null ? ($F{nilai_bahasa_ind}.doubleValue() >= 85 ? "SANGAT MEMADAI" : ($F{nilai_bahasa_ind}.doubleValue() >= 75 ? "MEMADAI" : "PERLU PENINGKATAN")) : "-"]]></textFieldExpression></textField>

			<!-- R5: B. Ing -->
			<staticText><reportElement x="0" y="302" width="200" height="16" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement verticalAlignment="Middle"><paragraph leftIndent="8"/></textElement><text><![CDATA[Bahasa Inggris]]></text></staticText>
			<textField><reportElement x="200" y="302" width="100" height="16" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_bahasa_ing}]]></textFieldExpression></textField>
			<textField><reportElement x="300" y="302" width="235" height="16" backcolor="#F5F7FA" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_bahasa_ing} != null ? ($F{nilai_bahasa_ing}.doubleValue() >= 85 ? "SANGAT MEMADAI" : ($F{nilai_bahasa_ing}.doubleValue() >= 75 ? "MEMADAI" : "PERLU PENINGKATAN")) : "-"]]></textFieldExpression></textField>

			<!-- R6: Seni -->
			<staticText><reportElement x="0" y="318" width="200" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement verticalAlignment="Middle"><paragraph leftIndent="8"/></textElement><text><![CDATA[Seni Budaya]]></text></staticText>
			<textField><reportElement x="200" y="318" width="100" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_seni}]]></textFieldExpression></textField>
			<textField><reportElement x="300" y="318" width="235" height="16"/><box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nilai_seni} != null ? ($F{nilai_seni}.doubleValue() >= 85 ? "SANGAT MEMADAI" : ($F{nilai_seni}.doubleValue() >= 75 ? "MEMADAI" : "PERLU PENINGKATAN")) : "-"]]></textFieldExpression></textField>

			<!-- RATA-RATA ROW -->
			<staticText><reportElement x="0" y="338" width="200" height="18" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#00897B"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><text><![CDATA[RATA-RATA AKADEMIK]]></text></staticText>
			<textField><reportElement x="200" y="338" width="100" height="18" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#00897B"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[($F{nilai_matematika} != null && $F{nilai_ipa} != null) ? new java.text.DecimalFormat("0.00").format(($F{nilai_matematika}.doubleValue() + $F{nilai_ipa}.doubleValue() + $F{nilai_ips}.doubleValue() + $F{nilai_bahasa_ind}.doubleValue() + $F{nilai_bahasa_ing}.doubleValue() + $F{nilai_seni}.doubleValue()) / 6.0) : "-"]]></textFieldExpression></textField>
			<textField><reportElement x="300" y="338" width="235" height="18" forecolor="#FFFFFF" backcolor="#00897B" mode="Opaque"/><box><pen lineWidth="0.5" lineColor="#00897B"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[($F{nilai_matematika} != null && $F{nilai_ipa} != null) ? (((($F{nilai_matematika}.doubleValue() + $F{nilai_ipa}.doubleValue() + $F{nilai_ips}.doubleValue() + $F{nilai_bahasa_ind}.doubleValue() + $F{nilai_bahasa_ing}.doubleValue() + $F{nilai_seni}.doubleValue()) / 6.0) >= 85) ? "EXCELLENT" : ((($F{nilai_matematika}.doubleValue() + $F{nilai_ipa}.doubleValue() + $F{nilai_ips}.doubleValue() + $F{nilai_bahasa_ind}.doubleValue() + $F{nilai_bahasa_ing}.doubleValue() + $F{nilai_seni}.doubleValue()) / 6.0) >= 75) ? "GOOD" : "NEEDS IMPROVEMENT") : "-"]]></textFieldExpression></textField>

			<!-- Footnote -->
			<staticText><reportElement x="0" y="365" width="535" height="12" forecolor="#9E9E9E"/><textElement><font size="7" isItalic="true"/></textElement><text><![CDATA[*Kategori: SANGAT MEMADAI (≥85) | MEMADAI (≥75) | PERLU PENINGKATAN (<75). Rata-rata dihitung dari 6 mata pelajaran inti.]]></text></staticText>

