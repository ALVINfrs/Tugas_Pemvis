<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="LaporanKomparasiTahun" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e05b7661-8cf3-40a0-ba12-f19b5e5a2862">
	<parameter name="paramTahun1" class="java.lang.String"/>
	<parameter name="paramTahun2" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[
        SELECT s.tahun_ajaran, j.nama as jurusan, COUNT(k.id) as total_peminat
        FROM konsultasi k
        JOIN siswa s ON k.siswa_id = s.id
        JOIN jurusan_kuliah j ON k.rekomendasi_utama_id = j.id
        WHERE s.tahun_ajaran IN ($P{paramTahun1}, $P{paramTahun2})
        GROUP BY s.tahun_ajaran, j.nama
        ORDER BY j.nama ASC, s.tahun_ajaran ASC
        ]]>
	</queryString>
	<field name="tahun_ajaran" class="java.lang.String"/>
	<field name="jurusan" class="java.lang.String"/>
	<field name="total_peminat" class="java.lang.Long"/>
	<group name="GroupJurusan">
		<groupExpression><![CDATA[$F{jurusan}]]></groupExpression>
		<groupHeader>
			<band height="30">
				<textField>
					<reportElement x="0" y="0" width="555" height="30" uuid="20000000-0000-0000-0000-000000000001"/>
