<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="LaporanRekapKonsultasi" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e05b7661-8cf3-40a0-ba12-f19b5e5a2862">
	<parameter name="paramKelas" class="java.lang.String"/>
	<parameter name="paramStatus" class="java.lang.String"/>
	<parameter name="paramTahun" class="java.lang.String"/>
	<parameter name="paramSemester" class="java.lang.String"/>
	<parameter name="paramStartDate" class="java.sql.Timestamp"/>
	<parameter name="paramEndDate" class="java.sql.Timestamp"/>
	<queryString language="SQL">
		<![CDATA[
        SELECT k.no_konsultasi, s.nama as nama_siswa, s.kelas, j.nama as jurusan, c.nama as konselor, k.tanggal_konsultasi, k.status
        FROM konsultasi k
        JOIN siswa s ON k.siswa_id = s.id
        JOIN konselor c ON k.konselor_id = c.id
        LEFT JOIN jurusan_kuliah j ON k.rekomendasi_utama_id = j.id
        WHERE 
          ($P{paramKelas} = 'Semua Kelas' OR s.kelas = $P{paramKelas}) AND
          ($P{paramStatus} = 'Semua Status' OR k.status = REPLACE(LOWER($P{paramStatus}), ' ', '_')) AND
          ($P{paramTahun} = 'Semua Tahun' OR s.tahun_ajaran = $P{paramTahun}) AND
          ($P{paramSemester} = 'Semua Semester' OR s.semester = $P{paramSemester}) AND
          k.tanggal_konsultasi BETWEEN $P{paramStartDate} AND $P{paramEndDate}
        ORDER BY k.tanggal_konsultasi DESC
        ]]>
	</queryString>
	<field name="no_konsultasi" class="java.lang.String"/>
	<field name="nama_siswa" class="java.lang.String"/>
	<field name="kelas" class="java.lang.String"/>
	<field name="jurusan" class="java.lang.String"/>
	<field name="konselor" class="java.lang.String"/>
	<field name="tanggal_konsultasi" class="java.sql.Timestamp"/>
	<field name="status" class="java.lang.String"/>
